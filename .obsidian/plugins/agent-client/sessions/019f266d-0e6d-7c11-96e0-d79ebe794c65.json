          "toolCallId": "ws_01dd12dad6ad925e016a4c7300f82481918c09029414712867",
          "title": "Searching for: Obsidian Git plugin GitHub Obsidian sync GitHub community plugin, Obsidian Git community plugin GitHub repository",
          "status": "completed",
          "kind": "fetch",
          "content": [],
          "rawInput": {
            "query": "Obsidian Git plugin GitHub Obsidian sync GitHub community plugin",
            "action": {
              "type": "search",
              "query": "Obsidian Git plugin GitHub Obsidian sync GitHub community plugin",
              "queries": [
                "Obsidian Git plugin GitHub Obsidian sync GitHub community plugin",
                "Obsidian Git community plugin GitHub repository"
